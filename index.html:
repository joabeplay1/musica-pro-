<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AuraStream - Música Premium Futurista</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Orbitron:wght@400;700&display=swap');

        :root {
            --primary-color: #00e6e6; /* Neon Cyan */
            --secondary-color: #ff00ff; /* Neon Magenta */
            --dark-bg: #1a0a2a; /* Deep Purple-ish Dark */
            --card-bg: rgba(255, 255, 255, 0.08); /* Transparent White for Glassmorphism */
            --text-color: #e0e0e0;
            --light-text: #f0f0f0;
            --glow-shadow: 0 0 15px var(--primary-color), 0 0 25px var(--primary-color);
            --button-glow: 0 0 8px var(--primary-color), 0 0 15px var(--primary-color);
            --transition-speed: 0.3s ease-in-out;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-color);
            overflow: hidden; /* Hide scrollbar for particle canvas */
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: relative;
        }

        /* Particle Canvas */
        #particle-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none; /* Allow clicks to pass through */
        }

        /* Main App Container */
        .app-container {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
            padding: 20px;
            gap: 20px;
        }

        /* Glassmorphism Card Base */
        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            padding: 25px;
            transition: transform var(--transition-speed), box-shadow var(--transition-speed);
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--glow-shadow);
        }

        /* Navigation */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0 0 20px 20px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .navbar .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8em;
            font-weight: 700;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
            letter-spacing: 1px;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1em;
            position: relative;
            transition: color var(--transition-speed);
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -5px;
            width: 0;
            height: 3px;
            background: var(--primary-color);
            box-shadow: var(--glow-shadow);
            transition: width var(--transition-speed);
        }

        .nav-links a:hover,
        .nav-links a.active {
            color: var(--primary-color);
            text-shadow: 0 0 5px var(--primary-color);
        }

        .nav-links a:hover::after,
        .nav-links a.active::after {
            width: 100%;
        }

        .user-controls {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .user-controls button {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 10px 20px;
            border-radius: 25px;
            color: var(--light-text);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-speed);
            box-shadow: var(--button-glow);
            position: relative;
            overflow: hidden;
        }

        .user-controls button:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 15px var(--primary-color), 0 0 25px var(--secondary-color);
        }

        .user-controls button:active {
            transform: translateY(0);
            box-shadow: 0 0 5px var(--primary-color);
        }

        .user-controls .profile-icon {
            font-size: 1.5em;
            color: var(--primary-color);
            cursor: pointer;
            transition: color var(--transition-speed), transform var(--transition-speed);
            text-shadow: 0 0 5px var(--primary-color);
        }

        .user-controls .profile-icon:hover {
            color: var(--secondary-color);
            transform: scale(1.1);
            text-shadow: 0 0 8px var(--secondary-color);
        }

        /* Main Content Area */
        .content-area {
            flex-grow: 1;
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            padding: 20px;
            overflow-y: auto; /* Enable scrolling for content */
            -ms-overflow-style: none; /* IE and Edge */
            scrollbar-width: none; /* Firefox */
        }
        .content-area::-webkit-scrollbar {
            display: none; /* Chrome, Safari, Opera */
        }

        .content-section {
            display: none;
            flex-direction: column;
            gap: 20px;
        }

        .content-section.active {
            display: flex;
        }

        /* Home Section */
        .home-section {
            text-align: center;
            padding: 50px;
            animation: fadeIn 1s ease-out;
        }

        .home-section h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 3.5em;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
            margin-bottom: 20px;
        }

        .home-section p {
            font-size: 1.2em;
            max-width: 800px;
            margin: 0 auto 30px auto;
            line-height: 1.6;
        }

        .home-section .cta-button {
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 15px 40px;
            border-radius: 30px;
            color: var(--light-text);
            font-weight: 700;
            font-size: 1.2em;
            cursor: pointer;
            transition: all var(--transition-speed);
            box-shadow: 0 0 10px var(--primary-color), 0 0 20px var(--secondary-color);
        }

        .home-section .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px var(--primary-color), 0 0 35px var(--secondary-color);
        }

        /* Library Section */
        .library-section {
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 25px;
            display: grid; /* Override flex for grid layout */
        }

        .song-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all var(--transition-speed);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
        }

        .song-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 0 10px var(--primary-color), 0 0 20px var(--secondary-color);
        }

        .song-card img {
            width: 100%;
            max-width: 180px;
            height: auto;
            border-radius: 10px;
            margin-bottom: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            transition: transform var(--transition-speed);
        }

        .song-card:hover img {
            transform: scale(1.03);
        }

        .song-card h3 {
            font-size: 1.1em;
            margin-bottom: 5px;
            color: var(--light-text);
            font-weight: 600;
        }

        .song-card p {
            font-size: 0.9em;
            color: var(--text-color);
            opacity: 0.8;
        }

        .library-controls {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .library-controls button {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 12px 25px;
            border-radius: 20px;
            color: var(--light-text);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-speed);
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
        }

        .library-controls button:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: var(--primary-color);
            color: var(--primary-color);
            box-shadow: var(--button-glow);
            transform: translateY(-2px);
        }

        .library-controls button i {
            color: var(--primary-color);
            transition: color var(--transition-speed);
        }

        .library-controls button:hover i {
            color: var(--light-text);
        }

        /* Music Player Section */
        .player-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            padding: 30px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            animation: fadeIn 1s ease-out;
        }

        .player-cover {
            width: 250px;
            height: 250px;
            border-radius: 50%;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.6), var(--glow-shadow);
            animation: rotate 20s linear infinite;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .player-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

        .player-cover.paused {
            animation-play-state: paused;
        }

        .player-info {
            text-align: center;
        }

        .player-info h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.2em;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
            margin-bottom: 10px;
        }

        .player-info p {
            font-size: 1.1em;
            color: var(--text-color);
            opacity: 0.9;
        }

        .player-controls {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-top: 20px;
        }

        .player-controls button {
            background: none;
            border: none;
            color: var(--light-text);
            font-size: 2.5em;
            cursor: pointer;
            transition: all var(--transition-speed);
            text-shadow: 0 0 5px rgba(255, 255, 255, 0.3);
        }

        .player-controls button:hover {
            color: var(--primary-color);
            transform: scale(1.1);
            text-shadow: var(--glow-shadow);
        }

        .player-controls .play-pause-btn {
            font-size: 3.5em;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
        }

        .player-controls .play-pause-btn:hover {
            color: var(--secondary-color);
            transform: scale(1.15);
            text-shadow: 0 0 15px var(--secondary-color), 0 0 25px var(--secondary-color);
        }

        .progress-container {
            width: 80%;
            max-width: 600px;
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .progress-container .time {
            font-size: 0.9em;
            color: var(--text-color);
            min-width: 40px;
            text-align: center;
        }

        .progress-bar {
            flex-grow: 1;
            height: 8px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 5px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .progress {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            border-radius: 5px;
            transition: width 0.1s linear;
            position: relative;
        }

        .progress::after {
            content: '';
            position: absolute;
            right: 0;
            top: 50%;
            transform: translate(50%, -50%);
            width: 16px;
            height: 16px;
            background: var(--primary-color);
            border-radius: 50%;
            box-shadow: var(--glow-shadow);
            transition: background var(--transition-speed);
        }

        .progress-bar:hover .progress::after {
            background: var(--secondary-color);
        }

        .volume-container {
            width: 70%;
            max-width: 400px;
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .volume-container i {
            font-size: 1.5em;
            color: var(--primary-color);
            text-shadow: 0 0 5px var(--primary-color);
        }

        .volume-slider {
            flex-grow: 1;
            -webkit-appearance: none;
            appearance: none;
            height: 8px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 5px;
            outline: none;
            transition: background var(--transition-speed);
        }

        .volume-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 16px;
            height: 16px;
            background: var(--primary-color);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: var(--glow-shadow);
            transition: background var(--transition-speed);
        }

        .volume-slider::-moz-range-thumb {
            width: 16px;
            height: 16px;
            background: var(--primary-color);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: var(--glow-shadow);
            transition: background var(--transition-speed);
        }

        .volume-slider:hover::-webkit-slider-thumb,
        .volume-slider:hover::-moz-range-thumb {
            background: var(--secondary-color);
            box-shadow: 0 0 10px var(--secondary-color);
        }

        /* Profile Section */
        .profile-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 30px;
            padding: 30px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            animation: fadeIn 1s ease-out;
        }

        .profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4em;
            color: var(--light-text);
            box-shadow: var(--glow-shadow);
            margin-bottom: 20px;
        }

        .profile-info h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5em;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
            margin-bottom: 10px;
        }

        .profile-info p {
            font-size: 1.1em;
            color: var(--text-color);
            opacity: 0.9;
            margin-bottom: 5px;
        }

        .profile-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 100%;
            max-width: 400px;
            margin-top: 20px;
        }

        .profile-form label {
            font-weight: 600;
            color: var(--primary-color);
            text-shadow: 0 0 3px var(--primary-color);
        }

        .profile-form input {
            width: 100%;
            padding: 12px 15px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(0, 0, 0, 0.4);
            color: var(--light-text);
            font-size: 1em;
            transition: all var(--transition-speed);
        }

        .profile-form input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 8px var(--primary-color);
            background: rgba(0, 0, 0, 0.6);
        }

        .profile-form button {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            color: var(--light-text);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-speed);
            box-shadow: var(--button-glow);
            margin-top: 10px;
        }

        .profile-form button:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 15px var(--primary-color), 0 0 25px var(--secondary-color);
        }

        /* Login Section (initially hidden, shown via button) */
        .login-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            padding: 40px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 25px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            animation: fadeIn 1s ease-out;
            max-width: 500px;
            margin: auto;
        }

        .login-section h2 {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5em;
            color: var(--primary-color);
            text-shadow: var(--glow-shadow);
            margin-bottom: 20px;
        }

        .login-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
            width: 100%;
        }

        .login-form input {
            width: 100%;
            padding: 12px 15px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(0, 0, 0, 0.4);
            color: var(--light-text);
            font-size: 1em;
            transition: all var(--transition-speed);
        }

        .login-form input:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 8px var(--primary-color);
            background: rgba(0, 0, 0, 0.6);
        }

        .login-form button {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            color: var(--light-text);
            font-weight: 600;
            cursor: pointer;
            transition: all var(--transition-speed);
            box-shadow: var(--button-glow);
            margin-top: 10px;
        }

        .login-form button:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 15px var(--primary-color), 0 0 25px var(--secondary-color);
        }

        /* Responsive Design */
        @media (max-width: 992px) {
            .app-container {
                padding: 15px;
            }
            .navbar {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
                border-radius: 0 0 15px 15px;
            }
            .nav-links {
                gap: 20px;
                flex-wrap: wrap;
                justify-content: center;
            }
            .user-controls {
                margin-top: 10px;
            }
            .content-area {
                padding: 15px;
            }
            .library-section {
                grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            }
            .player-cover {
                width: 200px;
                height: 200px;
            }
            .player-info h2 {
                font-size: 1.8em;
            }
            .player-controls {
                gap: 20px;
            }
            .player-controls button {
                font-size: 2em;
            }
            .player-controls .play-pause-btn {
                font-size: 3em;
            }
            .progress-container, .volume-container {
                width: 95%;
            }
        }

        @media (max-width: 768px) {
            .navbar .logo {
                font-size: 1.5em;
            }
            .nav-links {
                font-size: 0.9em;
            }
            .home-section h1 {
                font-size: 2.5em;
            }
            .home-section p {
                font-size: 1em;
            }
            .home-section .cta-button {
                padding: 12px 30px;
                font-size: 1em;
            }
            .library-section {
                grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            }
            .song-card h3 {
                font-size: 1em;
            }
            .song-card p {
                font-size: 0.8em;
            }
            .library-controls {
                flex-direction: column;
                align-items: center;
            }
            .player-cover {
                width: 150px;
                height: 150px;
            }
            .player-info h2 {
                font-size: 1.5em;
            }
            .player-info p {
                font-size: 0.9em;
            }
            .player-controls button {
                font-size: 1.8em;
            }
            .player-controls .play-pause-btn {
                font-size: 2.5em;
            }
            .profile-avatar {
                width: 120px;
                height: 120px;
                font-size: 3em;
            }
            .profile-info h2 {
                font-size: 2em;
            }
            .profile-info p {
                font-size: 1em;
            }
            .profile-form, .login-form {
                max-width: 300px;
            }
        }

        /* Keyframe Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Visualizer (simple mock) */
        .visualizer {
            display: flex;
            justify-content: center;
            align-items: flex-end;
            height: 50px;
            width: 100%;
            max-width: 300px;
            margin-top: 20px;
            gap: 3px;
        }

        .bar {
            width: 5px;
            background: linear-gradient(to top, var(--primary-color), var(--secondary-color));
            border-radius: 2px;
            animation: visualize 0.8s ease-in-out infinite alternate;
            box-shadow: 0 0 5px var(--primary-color);
        }

        .bar:nth-child(1) { animation-delay: 0s; height: 30%; }
        .bar:nth-child(2) { animation-delay: 0.1s; height: 60%; }
        .bar:nth-child(3) { animation-delay: 0.2s; height: 40%; }
        .bar:nth-child(4) { animation-delay: 0.3s; height: 70%; }
        .bar:nth-child(5) { animation-delay: 0.4s; height: 50%; }
        .bar:nth-child(6) { animation-delay: 0.5s; height: 80%; }
        .bar:nth-child(7) { animation-delay: 0.6s; height: 35%; }
        .bar:nth-child(8) { animation-delay: 0.7s; height: 65%; }
        .bar:nth-child(9) { animation-delay: 0.8s; height: 45%; }
        .bar:nth-child(10) { animation-delay: 0.9s; height: 75%; }

        @keyframes visualize {
            0% { height: 20%; opacity: 0.7; }
            50% { height: 80%; opacity: 1; }
            100% { height: 30%; opacity: 0.8; }
        }
        .visualizer.paused .bar {
            animation-play-state: paused;
            height: 20% !important; /* Keep bars low when paused */
        }

    </style>
</head>
<body>
    <canvas id="particle-canvas"></canvas>

    <div class="navbar">
        <div class="logo">AuraStream</div>
        <div class="nav-links">
            <a href="#" data-section="home" class="active">Início</a>
            <a href="#" data-section="library">Biblioteca</a>
            <a href="#" data-section="player">Player</a>
            <a href="#" data-section="playlists">Playlists</a>
        </div>
        <div class="user-controls">
            <button id="login-btn">Login</button>
            <i class="fas fa-user-circle profile-icon" data-section="profile"></i>
        </div>
    </div>

    <div class="app-container">
        <div class="content-area">
            <section id="home" class="content-section active">
                <div class="glass-card home-section">
                    <h1>Bem-vindo ao AuraStream</h1>
                    <p>Sua experiência musical premium e futurista. Mergulhe em um universo de sons com visuais imersivos e controles intuitivos.</p>
                    <button class="cta-button" onclick="showSection('library')">Explorar Música</button>
                </div>
            </section>

            <section id="library" class="content-section">
                <div class="glass-card" style="padding: 20px; margin-bottom: 20px;">
                    <h2 style="font-family: 'Orbitron', sans-serif; color: var(--primary-color); text-shadow: var(--glow-shadow); text-align: center; margin-bottom: 20px;">Sua Biblioteca Musical</h2>
                    <div class="library-controls">
                        <button onclick="addSongFromDrive()"><i class="fab fa-google-drive"></i> Adicionar do Google Drive</button>
                    </div>
                </div>
                <div class="library-section" id="song-list">
                    </div>
            </section>

            <section id="player" class="content-section">
                <div class="player-section">
                    <div class="player-cover" id="player-cover">
                        <img src="https://via.placeholder.com/250/00e6e6/ffffff?text=AuraStream" alt="Album Cover">
                    </div>
                    <div class="player-info">
                        <h2 id="player-title">Nenhuma Música Selecionada</h2>
                        <p id="player-artist">Artista Desconhecido</p>
                    </div>
                    <div class="visualizer" id="visualizer">
                        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
                        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
                    </div>
                    <div class="player-controls">
                        <button id="prev-btn"><i class="fas fa-backward"></i></button>
                        <button id="play-pause-btn" class="play-pause-btn"><i class="fas fa-play"></i></button>
                        <button id="next-btn"><i class="fas fa-forward"></i></button>
                    </div>
                    <div class="progress-container">
                        <span class="time" id="current-time">0:00</span>
                        <div class="progress-bar" id="progress-bar">
                            <div class="progress" id="progress"></div>
                        </div>
                        <span class="time" id="duration-time">0:00</span>
                    </div>
                    <div class="volume-container">
                        <i class="fas fa-volume-down"></i>
                        <input type="range" id="volume-slider" class="volume-slider" min="0" max="1" step="0.01" value="0.7">
                        <i class="fas fa-volume-up"></i>
                    </div>
                </div>
            </section>

            <section id="playlists" class="content-section">
                <div class="glass-card">
                    <h2 style="font-family: 'Orbitron', sans-serif; color: var(--primary-color); text-shadow: var(--glow-shadow); text-align: center; margin-bottom: 20px;">Minhas Playlists</h2>
                    <div id="playlist-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;">
                        <div class="glass-card" id="create-playlist-btn" style="padding: 20px; text-align: center; cursor: pointer;">
                            <i class="fas fa-plus-circle" style="font-size: 3em; color: var(--primary-color); margin-bottom: 10px;"></i>
                            <h3 style="color: var(--light-text);">Criar Nova Playlist</h3>
                        </div>
                    </div>
                </div>
            </section>

            <section id="profile" class="content-section">
                <div class="profile-section">
                    <div class="profile-avatar"><i class="fas fa-user"></i></div>
                    <div class="profile-info">
                        <h2 id="profile-username">Usuário AuraStream</h2>
                        <p id="profile-email">usuario@aurastream.com</p>
                    </div>
                    <form class="profile-form" onsubmit="event.preventDefault();">
                        <label for="edit-username">Nome de Usuário:</label>
                        <input type="text" id="edit-username" value="Usuário AuraStream">
                        <label for="edit-email">Email:</label>
                        <input type="email" id="edit-email" value="usuario@aurastream.com">
                        <button type="button" onclick="alert('Funcionalidade de edição de perfil requer backend. Dados não serão salvos.')">Salvar Perfil</button>
                    </form>
                </div>
            </section>

            <section id="login" class="content-section">
                <div class="login-section">
                    <h2>Login no AuraStream</h2>
                    <form class="login-form" onsubmit="event.preventDefault();">
                        <input type="text" placeholder="Nome de Usuário" required>
                        <input type="password" placeholder="Senha" required>
                        <button type="button" onclick="alert('Funcionalidade de login requer backend. Credenciais não serão verificadas.')">Entrar</button>
                        <button type="button" onclick="alert('Funcionalidade de registro requer backend.')" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">Registrar</button>
                    </form>
                </div>
            </section>
        </div>
    </div>

    <audio id="audio-player"></audio>

    <script>
        // --- Particle Animation ---
        const canvas = document.getElementById('particle-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        const numParticles = 100;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 1;
                this.speedX = Math.random() * 0.5 - 0.25;
                this.speedY = Math.random() * 0.5 - 0.25;
                this.color = `hsl(${Math.random() * 360}, 100%, 70%)`;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;

                if (this.size > 0.2) this.size -= 0.01;

                if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
                if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;
            }

            draw() {
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function initParticles() {
            particles = [];
            for (let i = 0; i < numParticles; i++) {
                particles.push(new Particle());
            }
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for (let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();

                if (particles[i].size <= 0.2) {
                    particles.splice(i, 1);
                    particles.push(new Particle());
                    i--;
                }
            }
            requestAnimationFrame(animateParticles);
        }

        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();
        initParticles();
        animateParticles();

        // --- Music Player Logic ---
        const audioPlayer = document.getElementById('audio-player');
        const playPauseBtn = document.getElementById('play-pause-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const progressBar = document.getElementById('progress-bar');
        const progress = document.getElementById('progress');
        const currentTimeSpan = document.getElementById('current-time');
        const durationTimeSpan = document.getElementById('duration-time');
        const volumeSlider = document.getElementById('volume-slider');
        const playerTitle = document.getElementById('player-title');
        const playerArtist = document.getElementById('player-artist');
        const playerCover = document.getElementById('player-cover');
        const visualizer = document.getElementById('visualizer');
        const songListDiv = document.getElementById('song-list');

        let currentSongIndex = 0;
        let isPlaying = false;

        // Mock song data (Google Drive links format)
        let songs = [
            {
                title: "Future Groove",
                artist: "Aura Beats",
                src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3", 
                cover: "https://picsum.photos/250/250?random=1"
            },
            {
                title: "Neon Dreams",
                artist: "Synthwave Collective",
                src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3",
                cover: "https://picsum.photos/250/250?random=2"
            },
            {
                title: "Cosmic Echoes",
                artist: "Starlight Sounds",
                src: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3",
                cover: "https://picsum.photos/250/250?random=3"
            }
        ];

        function formatTime(seconds) {
            if (isNaN(seconds)) return "0:00";
            const minutes = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${minutes}:${secs < 10 ? '0' : ''}${secs}`;
        }

        function loadSong(songIndex) {
            if (songs.length === 0) {
                playerTitle.textContent = "Nenhuma Música Selecionada";
                playerArtist.textContent = "Artista Desconhecido";
                playerCover.querySelector('img').src = "https://via.placeholder.com/250/00e6e6/ffffff?text=AuraStream";
                audioPlayer.src = "";
                progress.style.width = '0%';
                currentTimeSpan.textContent = '0:00';
                durationTimeSpan.textContent = '0:00';
                playPauseBtn.innerHTML = '<i class="fas fa-play"></i>';
                isPlaying = false;
                visualizer.classList.add('paused');
                playerCover.classList.add('paused');
                return;
            }

            currentSongIndex = songIndex;
            const song = songs[currentSongIndex];
            audioPlayer.src = song.src;
            playerTitle.textContent = song.title;
            playerArtist.textContent = song.artist;
            playerCover.querySelector('img').src = song.cover;

            if (isPlaying) {
                audioPlayer.play().catch(e => console.log("Erro ao reproduzir: ", e));
                playerCover.classList.remove('paused');
                visualizer.classList.remove('paused');
            } else {
                audioPlayer.load(); 
                playerCover.classList.add('paused');
                visualizer.classList.add('paused');
            }
            updatePlayPauseIcon();
        }

        function playPauseSong() {
            if (songs.length === 0) return;

            if (isPlaying) {
                audioPlayer.pause();
                playerCover.classList.add('paused');
                visualizer.classList.add('paused');
            } else {
                audioPlayer.play().catch(e => console.log("Erro ao reproduzir: ", e));
                playerCover.classList.remove('paused');
                visualizer.classList.remove('paused');
            }
            isPlaying = !isPlaying;
            updatePlayPauseIcon();
        }

        function updatePlayPauseIcon() {
            playPauseBtn.innerHTML = isPlaying ? '<i class="fas fa-pause"></i>' : '<i class="fas fa-play"></i>';
        }

        function nextSong() {
            if (songs.length === 0) return;
            currentSongIndex = (currentSongIndex + 1) % songs.length;
            loadSong(currentSongIndex);
            if (isPlaying) audioPlayer.play().catch(e => console.log(e));
        }

        function prevSong() {
            if (songs.length === 0) return;
            currentSongIndex = (currentSongIndex - 1 + songs.length) % songs.length;
            loadSong(currentSongIndex);
            if (isPlaying) audioPlayer.play().catch(e => console.log(e));
        }

        playPauseBtn.addEventListener('click', playPauseSong);
        nextBtn.addEventListener('click', nextSong);
        prevBtn.addEventListener('click', prevSong);

        audioPlayer.addEventListener('timeupdate', () => {
            const { currentTime, duration } = audioPlayer;
            if (duration) {
                const progressPercent = (currentTime / duration) * 100;
                progress.style.width = `${progressPercent}%`;
                currentTimeSpan.textContent = formatTime(currentTime);
            }
        });

        audioPlayer.addEventListener('loadedmetadata', () => {
            durationTimeSpan.textContent = formatTime(audioPlayer.duration);
        });

        audioPlayer.addEventListener('ended', nextSong);

        progressBar.addEventListener('click', (e) => {
            const width = progressBar.clientWidth;
            const clickX = e.offsetX;
            const duration = audioPlayer.duration;
            if (duration) {
                audioPlayer.currentTime = (clickX / width) * duration;
            }
        });

        volumeSlider.addEventListener('input', (e) => {
            audioPlayer.volume = e.target.value;
        });

        // --- UI Navigation ---
        const navLinks = document.querySelectorAll('.nav-links a');
        const contentSections = document.querySelectorAll('.content-section');
        const profileIcon = document.querySelector('.profile-icon');
        const loginButton = document.getElementById('login-btn');

        function showSection(sectionId) {
            contentSections.forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById(sectionId).classList.add('active');

            navLinks.forEach(link => {
                link.classList.remove('active');
            });
            const activeLink = document.querySelector(`.nav-links a[data-section="${sectionId}"]`);
            if (activeLink) {
                activeLink.classList.add('active');
            }
            
            if (sectionId === 'login') {
                loginButton.style.display = 'none';
                profileIcon.style.display = 'none';
            } else {
                loginButton.style.display = 'block';
                profileIcon.style.display = 'block';
            }
        }

        navLinks.forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                showSection(e.target.dataset.section);
            });
        });

        profileIcon.addEventListener('click', () => showSection('profile'));
        loginButton.addEventListener('click', () => showSection('login'));

        // --- Library and Playlist Management ---
        function renderSongList() {
            songListDiv.innerHTML = ''; 
            if (songs.length === 0) {
                songListDiv.innerHTML = '<p style="text-align: center; color: var(--text-color); opacity: 0.7; grid-column: 1/-1;">Nenhuma música na biblioteca. Adicione links do Google Drive!</p>';
                return;
            }
            songs.forEach((song, index) => {
                const songCard = document.createElement('div');
                songCard.classList.add('song-card', 'glass-card');
                songCard.innerHTML = `
                    <img src="${song.cover}" alt="${song.title} Cover">
                    <h3>${song.title}</h3>
                    <p>${song.artist}</p>
                `;
                songCard.addEventListener('click', () => {
                    isPlaying = true;
                    loadSong(index);
                    showSection('player');
                });
                songListDiv.appendChild(songCard);
            });
        }

        // Fluxo focado em adicionar via Google Drive Direct URL
        function addSongFromDrive() {
            const driveUrl = prompt("Insira o Link de Compartilhamento do arquivo de áudio no Google Drive:");
            if (!driveUrl) return;

            const songTitle = prompt("Insira o título da música:", "Nova Música do Drive");
            const artistName = prompt("Insira o nome do artista:", "Artista Desconhecido");
            const coverUrl = prompt("Insira a URL da imagem de capa (opcional):", "https://via.placeholder.com/250/00e6e6/ffffff?text=Drive");

            if (driveUrl && songTitle) {
                // Conversão básica de links padrões do drive para stream direto (id de visualização para uc?export=download)
                let directSrc = driveUrl;
                if (driveUrl.includes('file/d/')) {
                    const id = driveUrl.split('file/d/')[1].split('/')[0];
                    directSrc = `https://docs.google.com/uc?export=download&id=${id}`;
                } else if (driveUrl.includes('id=')) {
                    const id = driveUrl.split('id=')[1].split('&')[0];
                    directSrc = `https://docs.google.com/uc?export=download&id=${id}`;
                }

                const newSong = {
                    title: songTitle,
                    artist: artistName || "Artista Desconhecido",
                    src: directSrc,
                    cover: coverUrl || "https://via.placeholder.com/250/00e6e6/ffffff?text=Drive"
                };

                songs.push(newSong);
                renderSongList();
                alert(`Música "${newSong.title}" adicionada com sucesso da nuvem!`);
            }
        }

        // Mock Playlists (UI Rendering)
        const playlistListDiv = document.getElementById('playlist-list');
        let playlists = [
            { name: "Meus Favoritos", songs: [0, 1] },
            { name: "Chill Vibes", songs: [1] }
        ];

        function renderPlaylists() {
            const createButton = document.getElementById('create-playlist-btn');
            playlistListDiv.innerHTML = '';
            playlistListDiv.appendChild(createButton);

            playlists.forEach((playlist, index) => {
                const playlistCard = document.createElement('div');
                playlistCard.classList.add('glass-card');
                playlistCard.style.cssText = 'padding: 20px; text-align: center; cursor: pointer;';
                playlistCard.innerHTML = `
                    <i class="fas fa-compact-disc" style="font-size: 3em; color: var(--secondary-color); margin-bottom: 10px;"></i>
                    <h3 style="color: var(--light-text);">${playlist.name}</h3>
                    <p style="font-size: 0.9em; opacity: 0.8;">${playlist.songs.length} músicas</p>
                `;
                playlistCard.addEventListener('click', () => {
                    alert(`Reproduzindo playlist: ${playlist.name}`);
                });
                playlistListDiv.appendChild(playlistCard);
            });
        }

        document.getElementById('create-playlist-btn').addEventListener('click', (e) => {
            e.stopPropagation();
            const playlistName = prompt("Digite o nome da nova playlist:");
            if (playlistName) {
                playlists.push({ name: playlistName, songs: [] });
                renderPlaylists();
                alert(`Playlist "${playlistName}" criada!`);
            }
        });

        // Initial load
        document.addEventListener('DOMContentLoaded', () => {
            loadSong(currentSongIndex);
            renderSongList();
            renderPlaylists();
            showSection('home');
            visualizer.classList.add('paused');
            playerCover.classList.add('paused');
        });
    </script>
</body>
</html>
